{
  "name": "@bufbuild/protobuf-bench",
  "private": true,
  "type": "module",
  "description": "Benchmarks for @bufbuild/protobuf",
  "scripts": {
    "build": "../../node_modules/typescript/bin/tsc --noEmit",
    "generate": "buf generate",
    "postgenerate": "license-header src/gen",
    "bench": "tsx src/bench.ts",
    "profile": "node --cpu-prof --cpu-prof-dir .cpuprof --import tsx src/profile.ts",
    "format": "biome format --write",
    "license-header": "license-header",
    "lint": "biome lint --error-on-warnings"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@bufbuild/protobuf": "2.13.0",
    "tinybench": "^3.1.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.72.0",
    "@bufbuild/protoc-gen-es": "2.13.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4"
  }
}
