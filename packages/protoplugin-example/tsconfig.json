{
  "include": ["src/**/*.ts", "test/*.ts"],
  "compilerOptions": {
    "target": "es2017",
    "moduleResolution": "Node10",
    "resolveJsonModule": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  }
}
